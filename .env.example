# USERS anvands bara som bootstrap: vid forsta start seedas users-tabellen i
# databasen fran den har raden (forsta anvandaren blir admin). Darefter ar
# databasen kallan och nya anvandare laggs till via "Hantera anvandare" i UI:t.
USERS=hugo:replace-with-werkzeug-password-hash
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_SECURE=false
ENABLE_HSTS=false

DATABASE_URL=postgresql://dashboard:password@localhost/dashboard
ANTHROPIC_API_KEY=sk-ant-...
GARMIN_EMAIL=your-email@example.com
GARMIN_PASSWORD=your-garmin-password

AC_LOOP_SERVICE=ac-keeper-loop
AC_BEDTIME_OVERRIDE=data/ac_bedtime_override.json
WATER_TOKEN=replace-with-a-long-random-token
AC_BUTTON_TOKEN=replace-with-a-long-random-token

WEATHER_LOCATION=Smogen
WEATHER_LAT=58.35593
WEATHER_LON=11.22411
